# VSCode Extension Package Ignore
# 排除不需要打包的文件

# 开发文件
.vscode/**
.vscode-test/**
src/**
**/*.ts
!**/*.d.ts
**/*.map
tsconfig.json

# 构建工具
_bmad/**
_bmad-output/**
.claude/**

# 测试文件
test.md
**/*.test.ts
**/*.spec.ts

# Git
.git/**
.gitignore

# 其他
*.vsix
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store